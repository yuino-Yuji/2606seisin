# ===========================
# OS / Editor / IDE
# ===========================
.DS_Store
Thumbs.db
.vscode/
*.log

# ===========================
# Node / Sass / Build files
# ===========================
node_modules/
npm-debug.log
*.map          
# sourcemapは不要（SCSS再コンパイルで生成可能）

# ===========================
# Compiled CSS (from SCSS)
# ===========================
# Live Sass Compilerなどで自動生成されるCSSを除外
assets_yuino/css/*.css
!assets_yuino/css/reset_yd.css
assets_yuino/css/*.css.map

# ===========================
# LocalWP / Flywheel 環境ファイル
# ===========================
*.sql
local-site.json

# ===========================
# Cache / Backup / Temp
# ===========================
*.zip
*.tar.gz
*.bak
*.tmp
*.old
*.swp

# ===========================
# 念のため画像出力を除外したい場合（必要に応じて解除）
# ===========================
# assets_yuino/img/

# ===========================
# Agentルール
# ===========================
# .agent/rules は ~/shared-agent-rules への symlink（個別案件で張る）
.agent/

# ===========================
# Claude Code
# ===========================
# プロジェクト固有のClaude設定（pjid等の進行管理データを含む）
.claude/

# ===========================
# 個人ドキュメント
# ===========================
# 個人のセットアップ手順書（協働者には共有しない）
SETUP_GUIDE.md

# ===========================
# その他
# ===========================
.env
